{
  "kind": "collectionType",
  "collectionName": "refunds",
  "info": {
    "singularName": "refund",
    "pluralName": "refunds",
    "displayName": "Refund",
    "description": "Internal refund state linked to guarantee and payment workflows."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "payment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::payment.payment"
    },
    "candidate": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::candidate.candidate"
    },
    "enrollment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::enrollment.enrollment"
    },
    "paymentProvider": {
      "type": "enumeration",
      "enum": [
        "stripe"
      ],
      "default": "stripe",
      "required": true
    },
    "refundState": {
      "type": "enumeration",
      "enum": [
        "draft",
        "requested",
        "approved",
        "rejected",
        "submitted_to_provider",
        "processing",
        "completed",
        "failed",
        "cancelled"
      ],
      "default": "draft",
      "required": true
    },
    "amountPence": {
      "type": "integer",
      "min": 0,
      "required": true
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "default": "GBP",
      "required": true
    },
    "refundPercentage": {
      "type": "decimal",
      "min": 0,
      "max": 100
    },
    "reason": {
      "type": "text"
    },
    "eligibilitySource": {
      "type": "enumeration",
      "enum": [
        "interview_guarantee",
        "admin_override",
        "candidate_request",
        "payment_error",
        "other"
      ]
    },
    "qualifyingInterviewsDeliveredCount": {
      "type": "integer",
      "min": 0,
      "max": 1000
    },
    "providerRefundId": {
      "type": "string",
      "maxLength": 255,
      "unique": true
    },
    "requestedAt": {
      "type": "datetime"
    },
    "approvedAt": {
      "type": "datetime"
    },
    "processedAt": {
      "type": "datetime"
    },
    "metadata": {
      "type": "json"
    }
  }
}
