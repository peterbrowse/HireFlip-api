{
  "kind": "collectionType",
  "collectionName": "offers",
  "info": {
    "singularName": "offer",
    "pluralName": "offers",
    "displayName": "Progression Request",
    "description": "Non-binding employer request for candidate details so the employer can progress the candidate internally."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "candidate": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::candidate.candidate"
    },
    "employer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employer.employer"
    },
    "interview": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::interview.interview"
    },
    "progressionState": {
      "type": "enumeration",
      "enum": [
        "draft",
        "requested",
        "candidate_notified",
        "details_released",
        "accepted",
        "declined",
        "expired",
        "closed",
        "cancelled"
      ],
      "default": "requested",
      "required": true
    },
    "progressionType": {
      "type": "enumeration",
      "enum": [
        "second_interview",
        "final_interview",
        "practical_task",
        "introductory_call",
        "offer_discussion",
        "other"
      ]
    },
    "candidateMessage": {
      "type": "text"
    },
    "candidateResponse": {
      "type": "enumeration",
      "enum": [
        "accepted",
        "declined",
        "expired"
      ]
    },
    "candidateResponseDeadline": {
      "type": "datetime"
    },
    "candidateRespondedAt": {
      "type": "datetime"
    },
    "candidateDeclineReason": {
      "type": "text"
    },
    "employerFollowUpDueAt": {
      "type": "datetime"
    },
    "candidateFollowUpDueAt": {
      "type": "datetime"
    },
    "followUpState": {
      "type": "enumeration",
      "enum": [
        "not_due",
        "due",
        "sent",
        "completed",
        "cancelled"
      ],
      "default": "not_due"
    },
    "requestedByEmployerContact": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employer-contact.employer-contact"
    },
    "requestedDetailsAt": {
      "type": "datetime"
    },
    "candidateNotifiedAt": {
      "type": "datetime"
    },
    "detailsReleasedAt": {
      "type": "datetime"
    },
    "internalProcessNotes": {
      "type": "text"
    },
    "metadata": {
      "type": "json"
    }
  }
}
