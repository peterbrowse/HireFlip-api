{
  "kind": "collectionType",
  "collectionName": "offers",
  "info": {
    "singularName": "offer",
    "pluralName": "offers",
    "displayName": "Progression Request",
    "description": "Non-binding employer request for candidate details so the employer can progress the candidate internally."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "candidate": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::candidate.candidate"
    },
    "employer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employer.employer"
    },
    "interview": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::interview.interview"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "draft",
        "requested",
        "candidate_notified",
        "details_released",
        "closed",
        "cancelled"
      ],
      "default": "requested",
      "required": true
    },
    "requestedByEmployerContact": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employer-contact.employer-contact"
    },
    "requestedDetailsAt": {
      "type": "datetime"
    },
    "candidateNotifiedAt": {
      "type": "datetime"
    },
    "detailsReleasedAt": {
      "type": "datetime"
    },
    "internalProcessNotes": {
      "type": "text"
    },
    "metadata": {
      "type": "json"
    }
  }
}
