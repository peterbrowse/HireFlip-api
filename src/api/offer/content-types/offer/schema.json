{
  "kind": "collectionType",
  "collectionName": "offers",
  "info": {
    "singularName": "offer",
    "pluralName": "offers",
    "displayName": "Progression Request",
    "description": "Non-binding employer request for candidate details so the employer can progress the candidate internally."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "candidate": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::candidate.candidate"
    },
    "employer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employer.employer"
    },
    "interview": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::interview.interview"
    },
    "progressionState": {
      "type": "enumeration",
      "enum": [
        "draft",
        "requested",
        "candidate_notified",
        "details_released",
        "accepted",
        "declined",
        "expired",
        "closed",
        "cancelled"
      ],
      "default": "requested",
      "required": true
    },
    "progressionType": {
      "type": "enumeration",
      "enum": [
        "second_interview",
        "final_interview",
        "practical_task",
        "introductory_call",
        "offer_discussion",
        "other"
      ]
    },
    "candidateMessage": {
      "type": "text"
    },
    "candidateResponse": {
      "type": "enumeration",
      "enum": [
        "accepted",
        "declined",
        "expired"
      ]
    },
    "candidateResponseDeadline": {
      "type": "datetime"
    },
    "candidateRespondedAt": {
      "type": "datetime"
    },
    "candidateDeclineReason": {
      "type": "text"
    },
    "employerFollowUpDueAt": {
      "type": "datetime"
    },
    "candidateFollowUpDueAt": {
      "type": "datetime"
    },
    "employerFollowUpState": {
      "type": "enumeration",
      "enum": [
        "not_due",
        "sent",
        "reminded",
        "completed",
        "closed_no_response",
        "cancelled"
      ],
      "default": "not_due"
    },
    "candidateFollowUpState": {
      "type": "enumeration",
      "enum": [
        "not_due",
        "sent",
        "reminded",
        "completed",
        "closed_no_response",
        "cancelled"
      ],
      "default": "not_due"
    },
    "followUpState": {
      "type": "enumeration",
      "enum": [
        "not_due",
        "due",
        "sent",
        "completed",
        "cancelled"
      ],
      "default": "not_due"
    },
    "employerFollowUpSentAt": {
      "type": "datetime"
    },
    "candidateFollowUpSentAt": {
      "type": "datetime"
    },
    "employerFollowUpReminderSentAt": {
      "type": "datetime"
    },
    "candidateFollowUpReminderSentAt": {
      "type": "datetime"
    },
    "employerFollowUpCompletedAt": {
      "type": "datetime"
    },
    "candidateFollowUpCompletedAt": {
      "type": "datetime"
    },
    "employerFollowUpClosedAt": {
      "type": "datetime"
    },
    "candidateFollowUpClosedAt": {
      "type": "datetime"
    },
    "employerFollowUpOutcome": {
      "type": "enumeration",
      "enum": [
        "still_in_progress",
        "candidate_progressed_next_stage",
        "candidate_offered_role",
        "candidate_accepted_role",
        "candidate_rejected_or_withdrew",
        "employer_chose_not_to_continue",
        "no_response_from_candidate",
        "other"
      ]
    },
    "candidateFollowUpOutcome": {
      "type": "enumeration",
      "enum": [
        "still_in_progress",
        "progressed_to_another_stage",
        "received_offer",
        "accepted_role",
        "declined_or_withdrew",
        "employer_chose_not_to_continue",
        "employer_did_not_contact_me",
        "need_support"
      ]
    },
    "employerFollowUpResponses": {
      "type": "json"
    },
    "candidateFollowUpResponses": {
      "type": "json"
    },
    "employerFollowUpNotes": {
      "type": "text"
    },
    "candidateFollowUpNotes": {
      "type": "text"
    },
    "requestedByEmployerContact": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employer-contact.employer-contact"
    },
    "requestedDetailsAt": {
      "type": "datetime"
    },
    "candidateNotifiedAt": {
      "type": "datetime"
    },
    "detailsReleasedAt": {
      "type": "datetime"
    },
    "internalProcessNotes": {
      "type": "text"
    },
    "metadata": {
      "type": "json"
    }
  }
}
