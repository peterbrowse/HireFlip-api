{
  "kind": "collectionType",
  "collectionName": "interview_feedback",
  "info": {
    "singularName": "interview-feedback",
    "pluralName": "interview-feedback-records",
    "displayName": "Interview Feedback",
    "description": "Candidate or employer feedback after an interview."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "interview": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::interview.interview"
    },
    "submittedByType": {
      "type": "enumeration",
      "enum": [
        "candidate",
        "employer_contact",
        "external_interviewer",
        "admin",
        "system"
      ],
      "required": true
    },
    "feedbackInvite": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::interview-feedback-invite.interview-feedback-invite"
    },
    "submittedById": {
      "type": "string"
    },
    "outcome": {
      "type": "enumeration",
      "enum": [
        "positive",
        "neutral",
        "negative",
        "progressing",
        "not_progressing",
        "offer_expected",
        "unknown"
      ],
      "default": "unknown",
      "required": true
    },
    "rating": {
      "type": "integer"
    },
    "notes": {
      "type": "text"
    },
    "strengths": {
      "type": "text"
    },
    "concerns": {
      "type": "text"
    },
    "nextStep": {
      "type": "text"
    },
    "previousTakeawayAssessment": {
      "type": "text"
    },
    "candidateReportState": {
      "type": "enumeration",
      "enum": [
        "pending",
        "generated",
        "failed",
        "approved",
        "manually_edited"
      ],
      "default": "pending",
      "required": true
    },
    "candidateReportIntro": {
      "type": "text"
    },
    "candidateReportStrengths": {
      "type": "text"
    },
    "candidateReportImprovements": {
      "type": "text"
    },
    "candidateReportConclusion": {
      "type": "text"
    },
    "candidateReportTakeaways": {
      "type": "json"
    },
    "candidateReportGeneratedAt": {
      "type": "datetime"
    },
    "candidateReportVisibleAt": {
      "type": "datetime"
    },
    "candidateReportConcernState": {
      "type": "enumeration",
      "enum": [
        "none",
        "open",
        "dismissed",
        "resolved",
        "regenerated"
      ],
      "default": "none",
      "required": true
    },
    "candidateReportConcernReason": {
      "type": "text"
    },
    "candidateReportConcernFlaggedAt": {
      "type": "datetime"
    },
    "candidateReportConcernReviewedAt": {
      "type": "datetime"
    },
    "candidateReportConcernResolvedAt": {
      "type": "datetime"
    },
    "candidateReportConcernResolution": {
      "type": "text"
    },
    "candidateReportConcernResolvedByStaffEmail": {
      "type": "email",
      "maxLength": 254
    },
    "candidateReportConcernSupportCase": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::support-case.support-case"
    },
    "aiProvider": {
      "type": "string"
    },
    "aiModel": {
      "type": "string"
    },
    "aiPromptVersion": {
      "type": "string"
    },
    "aiMetadata": {
      "type": "json"
    },
    "submittedAt": {
      "type": "datetime"
    },
    "metadata": {
      "type": "json"
    }
  }
}
