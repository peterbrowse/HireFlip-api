{
  "kind": "collectionType",
  "collectionName": "candidates",
  "info": {
    "singularName": "candidate",
    "pluralName": "candidates",
    "displayName": "Candidate",
    "description": "People interested in, enrolled in, or progressed through HireFlip classes."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "authProvider": {
      "type": "enumeration",
      "enum": [
        "auth0",
        "manual",
        "unknown"
      ],
      "default": "unknown",
      "required": true
    },
    "authIdentityId": {
      "type": "string",
      "maxLength": 160,
      "unique": true
    },
    "email": {
      "type": "email",
      "maxLength": 254,
      "required": true,
      "unique": true
    },
    "firstName": {
      "type": "string",
      "maxLength": 120
    },
    "lastName": {
      "type": "string",
      "maxLength": 120
    },
    "phone": {
      "type": "string",
      "maxLength": 40
    },
    "age": {
      "type": "integer",
      "min": 16,
      "max": 120
    },
    "gender": {
      "type": "enumeration",
      "enum": [
        "woman",
        "man",
        "non_binary",
        "gender_diverse_or_gender_non_conforming",
        "agender",
        "self_describe",
        "prefer_not_to_say"
      ]
    },
    "genderSelfDescription": {
      "type": "string",
      "maxLength": 120
    },
    "profileImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "preferredCommunicationChannel": {
      "type": "enumeration",
      "enum": [
        "not_set",
        "email",
        "sms",
        "phone"
      ],
      "default": "not_set",
      "required": true
    },
    "marketingConsentState": {
      "type": "enumeration",
      "enum": [
        "not_asked",
        "opted_in",
        "opted_out",
        "withdrawn"
      ],
      "default": "not_asked",
      "required": true
    },
    "marketingConsentCapturedAt": {
      "type": "datetime"
    },
    "marketingConsentWordingVersion": {
      "type": "string",
      "maxLength": 80
    },
    "accountOnboardingCompletedAt": {
      "type": "datetime"
    },
    "candidateState": {
      "type": "enumeration",
      "enum": [
        "interest_registered",
        "account_created",
        "unenrolled",
        "enrolled",
        "alumni",
        "in_class",
        "course_completed",
        "passed",
        "failed",
        "interview_phase",
        "hired",
        "refunded",
        "suspended",
        "blacklisted",
        "archived"
      ],
      "default": "account_created",
      "required": true
    },
    "accountRestrictionStatus": {
      "type": "enumeration",
      "enum": [
        "active",
        "suspended",
        "blacklisted"
      ],
      "default": "active",
      "required": true
    },
    "accountRestrictionReason": {
      "type": "string",
      "maxLength": 160
    },
    "accountRestrictionMessage": {
      "type": "text"
    },
    "accountRestrictionEvidenceReference": {
      "type": "string",
      "maxLength": 240
    },
    "accountRestrictionAppealStatus": {
      "type": "enumeration",
      "enum": [
        "not_applicable",
        "not_started",
        "submitted",
        "under_review",
        "upheld",
        "rejected"
      ],
      "default": "not_applicable",
      "required": true
    },
    "accountRestrictedAt": {
      "type": "datetime"
    },
    "accountRestrictedBy": {
      "type": "string",
      "maxLength": 160
    },
    "region": {
      "type": "string",
      "maxLength": 120
    },
    "sector": {
      "type": "string",
      "maxLength": 120
    },
    "recruitmentPlatformVisibility": {
      "type": "enumeration",
      "enum": [
        "not_set",
        "visible",
        "hidden"
      ],
      "default": "not_set",
      "required": true
    },
    "profileSettings": {
      "type": "json"
    },
    "classAreaPreferences": {
      "type": "json"
    },
    "workSectorPreferences": {
      "type": "json"
    },
    "notificationPreferences": {
      "type": "json"
    },
    "registeredInterestAt": {
      "type": "datetime"
    },
    "accountCreatedAt": {
      "type": "datetime"
    }
  }
}
