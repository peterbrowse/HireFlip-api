{
  "kind": "collectionType",
  "collectionName": "candidates",
  "info": {
    "singularName": "candidate",
    "pluralName": "candidates",
    "displayName": "Candidate",
    "description": "People interested in, enrolled in, or progressed through HireFlip classes."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "authProvider": {
      "type": "enumeration",
      "enum": [
        "auth0",
        "manual",
        "unknown"
      ],
      "default": "unknown",
      "required": true
    },
    "authIdentityId": {
      "type": "string",
      "maxLength": 160,
      "unique": true
    },
    "email": {
      "type": "email",
      "maxLength": 254,
      "required": true,
      "unique": true
    },
    "firstName": {
      "type": "string",
      "maxLength": 120
    },
    "lastName": {
      "type": "string",
      "maxLength": 120
    },
    "phone": {
      "type": "string",
      "maxLength": 40
    },
    "profileImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "preferredCommunicationChannel": {
      "type": "enumeration",
      "enum": [
        "not_set",
        "email",
        "sms",
        "phone"
      ],
      "default": "not_set",
      "required": true
    },
    "marketingConsentState": {
      "type": "enumeration",
      "enum": [
        "not_asked",
        "opted_in",
        "opted_out",
        "withdrawn"
      ],
      "default": "not_asked",
      "required": true
    },
    "marketingConsentCapturedAt": {
      "type": "datetime"
    },
    "marketingConsentWordingVersion": {
      "type": "string",
      "maxLength": 80
    },
    "accountOnboardingCompletedAt": {
      "type": "datetime"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "interest_registered",
        "account_created",
        "waitlisted",
        "slot_reserved",
        "paid",
        "in_class",
        "course_completed",
        "passed",
        "failed",
        "interview_phase",
        "hired",
        "refunded",
        "archived"
      ],
      "default": "interest_registered",
      "required": true
    },
    "region": {
      "type": "string",
      "maxLength": 120
    },
    "sector": {
      "type": "string",
      "maxLength": 120
    },
    "recruitmentPlatformVisibility": {
      "type": "enumeration",
      "enum": [
        "not_set",
        "visible",
        "hidden"
      ],
      "default": "not_set",
      "required": true
    },
    "profileSettings": {
      "type": "json"
    },
    "notificationPreferences": {
      "type": "json"
    },
    "registeredInterestAt": {
      "type": "datetime"
    },
    "accountCreatedAt": {
      "type": "datetime"
    }
  }
}
