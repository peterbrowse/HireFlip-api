{
  "kind": "collectionType",
  "collectionName": "enrollments",
  "info": {
    "singularName": "enrollment",
    "pluralName": "enrollments",
    "displayName": "Enrollment",
    "description": "Connects a candidate to a HireFlip class and tracks class-level eligibility state."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "candidate": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::candidate.candidate"
    },
    "class": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::class.class"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "interest_registered",
        "interest_withdrawn",
        "enrollment_open",
        "place_reserved",
        "waiting_list",
        "missed_out",
        "enrolled",
        "payment_exception",
        "in_class",
        "interview_phase",
        "completed",
        "failed",
        "withdrawn",
        "refunded",
        "removed_no_refund",
        "removed_partial_refund",
        "removed_full_refund"
      ],
      "default": "interest_registered",
      "required": true
    },
    "paymentStatus": {
      "type": "enumeration",
      "enum": [
        "not_required",
        "pending",
        "paid",
        "requires_review",
        "failed",
        "partially_refunded",
        "refunded"
      ],
      "default": "pending",
      "required": true
    },
    "completionStatus": {
      "type": "enumeration",
      "enum": [
        "not_started",
        "in_progress",
        "completed",
        "missed_deadline"
      ],
      "default": "not_started",
      "required": true
    },
    "passStatus": {
      "type": "enumeration",
      "enum": [
        "not_assessed",
        "passed",
        "failed",
        "appealed"
      ],
      "default": "not_assessed",
      "required": true
    },
    "interestRegisteredAt": {
      "type": "datetime"
    },
    "invitedToJoinAt": {
      "type": "datetime"
    },
    "reservationExpiresAt": {
      "type": "datetime"
    },
    "waitingListPosition": {
      "type": "integer",
      "min": 1
    },
    "missedOutAt": {
      "type": "datetime"
    },
    "beganClassAt": {
      "type": "datetime"
    },
    "enrolledAt": {
      "type": "datetime"
    },
    "completedAt": {
      "type": "datetime"
    },
    "passedAt": {
      "type": "datetime"
    },
    "interviewGuaranteeWindowStartsAt": {
      "type": "datetime"
    },
    "interviewGuaranteeDeadline": {
      "type": "datetime"
    },
    "qualifyingInterviewsDeliveredCount": {
      "type": "integer",
      "default": 0,
      "required": true
    },
    "refundEligibilityState": {
      "type": "enumeration",
      "enum": [
        "not_assessed",
        "not_eligible",
        "potentially_eligible",
        "eligible_25",
        "eligible_50",
        "refund_requested",
        "refund_processed",
        "forfeited"
      ],
      "default": "not_assessed",
      "required": true
    },
    "metadata": {
      "type": "json"
    }
  }
}
