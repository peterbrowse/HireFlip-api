{
  "kind": "collectionType",
  "collectionName": "interview_slot_offers",
  "info": {
    "singularName": "interview-slot-offer",
    "pluralName": "interview-slot-offers",
    "displayName": "Interview Slot Offer",
    "description": "A grouped 3-option employer interview slot offer for candidate selection."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "candidate": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::candidate.candidate",
      "inversedBy": "interviewSlotOffers"
    },
    "enrollment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::enrollment.enrollment"
    },
    "employer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employer.employer",
      "inversedBy": "interviewSlotOffers"
    },
    "employerContact": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employer-contact.employer-contact"
    },
    "interviewRequest": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::interview-request.interview-request",
      "inversedBy": "slotOffers"
    },
    "capacityClaim": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employer-capacity-claim.employer-capacity-claim"
    },
    "slots": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::interview-slot.interview-slot",
      "mappedBy": "slotOffer"
    },
    "selectedSlot": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::interview-slot.interview-slot"
    },
    "selectedInterview": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::interview.interview"
    },
    "requiredSlotCount": {
      "type": "integer",
      "min": 1,
      "max": 3,
      "default": 3,
      "required": true
    },
    "offerState": {
      "type": "enumeration",
      "enum": [
        "draft",
        "submitted",
        "sent",
        "candidate_selected",
        "candidate_declined",
        "expired",
        "cancelled",
        "completed",
        "replacement_required"
      ],
      "default": "submitted",
      "required": true
    },
    "candidateNotifiedAt": {
      "type": "datetime"
    },
    "candidateResponseDeadline": {
      "type": "datetime"
    },
    "candidateRespondedAt": {
      "type": "datetime"
    },
    "candidateWarningState": {
      "type": "enumeration",
      "enum": [
        "none",
        "warning_sent",
        "strike_applied"
      ],
      "default": "none",
      "required": true
    },
    "candidateWarningSentAt": {
      "type": "datetime"
    },
    "candidateResponseReminderCount": {
      "type": "integer",
      "min": 0,
      "default": 0,
      "required": true
    },
    "lastCandidateResponseReminderSentAt": {
      "type": "datetime"
    },
    "candidateInterviewFormatPreference": {
      "type": "enumeration",
      "enum": [
        "in_person",
        "remote",
        "no_preference"
      ]
    },
    "declineReason": {
      "type": "enumeration",
      "enum": [
        "health_or_family_emergency",
        "another_interview",
        "travel_disruption",
        "other"
      ]
    },
    "declineNote": {
      "type": "text"
    },
    "internalNote": {
      "type": "text"
    },
    "metadata": {
      "type": "json"
    }
  }
}
