{
  "kind": "collectionType",
  "collectionName": "course_answer_submissions",
  "info": {
    "singularName": "course-answer-submission",
    "pluralName": "course-answer-submissions",
    "displayName": "Course Answer Submission",
    "description": "Candidate answer submitted during a HireFlip course test attempt."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "candidate": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::candidate.candidate"
    },
    "courseTestAttempt": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course-test-attempt.course-test-attempt"
    },
    "courseQuestion": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course-question.course-question"
    },
    "answerPayload": {
      "type": "json"
    },
    "submittedAt": {
      "type": "datetime"
    },
    "score": {
      "type": "decimal"
    },
    "feedback": {
      "type": "text"
    },
    "flagState": {
      "type": "enumeration",
      "enum": [
        "none",
        "flagged",
        "cleared",
        "confirmed"
      ],
      "default": "none",
      "required": true
    },
    "metadata": {
      "type": "json"
    }
  }
}
