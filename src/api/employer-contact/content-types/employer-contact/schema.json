{
  "kind": "collectionType",
  "collectionName": "employer_contacts",
  "info": {
    "singularName": "employer-contact",
    "pluralName": "employer-contacts",
    "displayName": "Employer Contact",
    "description": "Nominated contacts who manage employer participation and interview workflows."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "employer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employer.employer",
      "inversedBy": "contacts"
    },
    "authProvider": {
      "type": "enumeration",
      "enum": [
        "auth0",
        "manual",
        "unknown"
      ],
      "default": "unknown",
      "required": true
    },
    "authIdentityId": {
      "type": "string",
      "maxLength": 160,
      "unique": true
    },
    "email": {
      "type": "email",
      "maxLength": 254,
      "required": true
    },
    "firstName": {
      "type": "string",
      "maxLength": 120
    },
    "lastName": {
      "type": "string",
      "maxLength": 120
    },
    "phone": {
      "type": "string",
      "maxLength": 40
    },
    "profileImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "roleTitle": {
      "type": "string",
      "maxLength": 160
    },
    "contactRole": {
      "type": "enumeration",
      "enum": [
        "lead_contact",
        "team_contact"
      ],
      "default": "team_contact",
      "required": true
    },
    "coverageRegions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::class-area.class-area"
    },
    "coverageConfirmedAt": {
      "type": "datetime"
    },
    "coverageConfirmedByEmail": {
      "type": "email",
      "maxLength": 254
    },
    "contactState": {
      "type": "enumeration",
      "enum": [
        "invited",
        "listed",
        "active",
        "disabled",
        "archived"
      ],
      "default": "invited",
      "required": true
    },
    "notificationPreferences": {
      "type": "json"
    },
    "invitedAt": {
      "type": "datetime"
    },
    "accountCreatedAt": {
      "type": "datetime"
    }
  }
}
