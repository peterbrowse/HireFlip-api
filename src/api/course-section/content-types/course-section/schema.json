{
  "kind": "collectionType",
  "collectionName": "course_sections",
  "info": {
    "singularName": "course-section",
    "pluralName": "course-sections",
    "displayName": "Course Section",
    "description": "A major section inside a HireFlip course."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course",
      "inversedBy": "sections"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "required": true
    },
    "description": {
      "type": "text"
    },
    "sortOrder": {
      "type": "integer",
      "min": 0,
      "default": 0,
      "required": true
    },
    "required": {
      "type": "boolean",
      "default": true,
      "required": true
    },
    "sectionState": {
      "type": "enumeration",
      "enum": [
        "draft",
        "active",
        "archived"
      ],
      "default": "draft",
      "required": true
    },
    "modules": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::course-module.course-module",
      "mappedBy": "courseSection"
    }
  }
}
