{
  "kind": "collectionType",
  "collectionName": "public_interest_leads",
  "info": {
    "singularName": "public-interest-lead",
    "pluralName": "public-interest-leads",
    "displayName": "Public Interest Lead",
    "description": "Public-site register-interest or enquiry submission before full account creation."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "email": {
      "type": "email",
      "maxLength": 254,
      "required": true
    },
    "leadType": {
      "type": "enumeration",
      "enum": [
        "candidate_interest",
        "employer_enquiry",
        "unsupported_region_sector",
        "other"
      ],
      "required": true
    },
    "name": {
      "type": "string",
      "maxLength": 120
    },
    "company": {
      "type": "string",
      "maxLength": 160
    },
    "candidateStatus": {
      "type": "string",
      "maxLength": 120
    },
    "employerInterviewCapacity": {
      "type": "integer",
      "min": 0,
      "max": 1000
    },
    "region": {
      "type": "string",
      "maxLength": 120
    },
    "sector": {
      "type": "string",
      "maxLength": 120
    },
    "sourceForm": {
      "type": "string",
      "maxLength": 80
    },
    "consentState": {
      "type": "enumeration",
      "enum": [
        "not_requested",
        "operational_only",
        "marketing_opted_in",
        "marketing_withdrawn"
      ],
      "default": "not_requested",
      "required": true
    },
    "marketingChannels": {
      "type": "json"
    },
    "consentCapturedAt": {
      "type": "datetime"
    },
    "consentWordingVersion": {
      "type": "string",
      "maxLength": 80
    },
    "privacyNoticeVersion": {
      "type": "string",
      "maxLength": 80
    },
    "enquiryLawfulBasis": {
      "type": "string",
      "maxLength": 120
    },
    "marketingLawfulBasis": {
      "type": "string",
      "maxLength": 120
    },
    "unsubscribedAt": {
      "type": "datetime"
    },
    "suppressionStatus": {
      "type": "enumeration",
      "enum": [
        "not_suppressed",
        "suppressed",
        "deleted",
        "anonymised"
      ],
      "default": "not_suppressed",
      "required": true
    },
    "mailingPlatformProvider": {
      "type": "string",
      "maxLength": 80
    },
    "mailingPlatformContactId": {
      "type": "string",
      "maxLength": 160
    },
    "mailingPlatformListId": {
      "type": "string",
      "maxLength": 160
    },
    "syncStatus": {
      "type": "enumeration",
      "enum": [
        "not_required",
        "pending",
        "synced",
        "failed"
      ],
      "default": "not_required",
      "required": true
    },
    "syncError": {
      "type": "text"
    },
    "linkedCandidate": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::candidate.candidate"
    },
    "linkedEmployer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employer.employer"
    },
    "metadata": {
      "type": "json"
    }
  }
}
