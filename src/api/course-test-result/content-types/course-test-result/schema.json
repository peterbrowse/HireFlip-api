{
  "kind": "collectionType",
  "collectionName": "course_test_results",
  "info": {
    "singularName": "course-test-result",
    "pluralName": "course-test-results",
    "displayName": "Course Test Result",
    "description": "Snapshot result for a candidate course test attempt."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "candidate": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::candidate.candidate"
    },
    "enrollment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::enrollment.enrollment"
    },
    "courseTest": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course-test.course-test"
    },
    "courseTestAttempt": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::course-test-attempt.course-test-attempt"
    },
    "resultState": {
      "type": "enumeration",
      "enum": [
        "not_assessed",
        "passed",
        "failed",
        "appealed",
        "void"
      ],
      "default": "not_assessed",
      "required": true
    },
    "score": {
      "type": "decimal"
    },
    "maxScore": {
      "type": "decimal"
    },
    "passMarkSnapshot": {
      "type": "decimal"
    },
    "passed": {
      "type": "boolean"
    },
    "attemptNumber": {
      "type": "integer"
    },
    "retryEligibilityState": {
      "type": "enumeration",
      "enum": [
        "not_assessed",
        "eligible_open_retry",
        "eligible_conditional_retry",
        "not_eligible",
        "exhausted"
      ],
      "default": "not_assessed",
      "required": true
    },
    "decidedAt": {
      "type": "datetime"
    },
    "metadata": {
      "type": "json"
    }
  }
}
