{
  "kind": "collectionType",
  "collectionName": "admin_tasks",
  "info": {
    "singularName": "admin-task",
    "pluralName": "admin-tasks",
    "displayName": "Admin Task",
    "description": "Operational tasks surfaced in the custom admin dashboard."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "taskKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 220,
      "required": true,
      "unique": true
    },
    "taskType": {
      "type": "enumeration",
      "enum": [
        "assessment_appeal",
        "ai_feedback_review",
        "class_readiness",
        "interview_operation",
        "privacy_request",
        "payment_review",
        "refund_review",
        "support_case",
        "notification_failure",
        "system_alert"
      ],
      "required": true
    },
    "taskState": {
      "type": "enumeration",
      "enum": [
        "open",
        "acknowledged",
        "resolved",
        "dismissed"
      ],
      "default": "open",
      "required": true
    },
    "priority": {
      "type": "enumeration",
      "enum": [
        "low",
        "normal",
        "high",
        "urgent"
      ],
      "default": "normal",
      "required": true
    },
    "priorityRank": {
      "type": "integer",
      "min": 0,
      "default": 2,
      "required": true
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180,
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "sourceType": {
      "type": "enumeration",
      "enum": [
        "assessment_appeal",
        "payment",
        "refund",
        "reservation",
        "enrollment",
        "support_case",
        "interview_feedback",
        "interview",
        "interview_request",
        "progression_request",
        "privacy_rights_request",
        "notification_event",
        "audit_event",
        "class"
      ],
      "required": true
    },
    "sourceDocumentId": {
      "type": "string",
      "maxLength": 160
    },
    "relatedType": {
      "type": "string",
      "maxLength": 120
    },
    "relatedDocumentId": {
      "type": "string",
      "maxLength": 160
    },
    "actionLabel": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "required": true
    },
    "actionPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "required": true
    },
    "lastDetectedAt": {
      "type": "datetime"
    },
    "dueAt": {
      "type": "datetime"
    },
    "candidateLabel": {
      "type": "string",
      "maxLength": 240
    },
    "employerLabel": {
      "type": "string",
      "maxLength": 240
    },
    "classLabel": {
      "type": "string",
      "maxLength": 240
    },
    "regionLabel": {
      "type": "string",
      "maxLength": 160
    },
    "issueKey": {
      "type": "string",
      "maxLength": 120
    },
    "ownerKeyText": {
      "type": "text"
    },
    "searchText": {
      "type": "text"
    },
    "resolvedAt": {
      "type": "datetime"
    },
    "metadata": {
      "type": "json"
    }
  }
}
