{
  "kind": "collectionType",
  "collectionName": "employers",
  "info": {
    "singularName": "employer",
    "pluralName": "employers",
    "displayName": "Employer",
    "description": "Companies participating in HireFlip hiring workflows."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "companyName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "prospect",
        "invited",
        "active",
        "paused",
        "archived"
      ],
      "default": "prospect",
      "required": true
    },
    "region": {
      "type": "string",
      "maxLength": 120
    },
    "sectorInterests": {
      "type": "json"
    },
    "roleInterests": {
      "type": "json"
    },
    "assignmentMode": {
      "type": "enumeration",
      "enum": [
        "automatic",
        "manual_masked_cv_review",
        "criteria_matching"
      ],
      "default": "automatic",
      "required": true
    },
    "interviewCommitmentVolume": {
      "type": "integer",
      "min": 0,
      "max": 1000
    },
    "initialInterviewCommitmentVolume": {
      "type": "integer",
      "min": 0,
      "max": 1000
    },
    "interviewCommitmentCadence": {
      "type": "enumeration",
      "enum": [
        "not_set",
        "quarterly",
        "biannually",
        "annually"
      ],
      "default": "not_set",
      "required": true
    },
    "initialInterviewCommitmentCadence": {
      "type": "enumeration",
      "enum": [
        "not_set",
        "quarterly",
        "biannually",
        "annually"
      ],
      "default": "not_set",
      "required": true
    },
    "capacityChangeRequestStatus": {
      "type": "enumeration",
      "enum": [
        "none",
        "pending",
        "approved",
        "denied"
      ],
      "default": "none",
      "required": true
    },
    "notes": {
      "type": "text"
    },
    "contacts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::employer-contact.employer-contact",
      "mappedBy": "employer"
    },
    "capacityChangeRequests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::employer-capacity-change-request.employer-capacity-change-request",
      "mappedBy": "employer"
    }
  }
}
