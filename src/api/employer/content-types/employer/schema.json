{
  "kind": "collectionType",
  "collectionName": "employers",
  "info": {
    "singularName": "employer",
    "pluralName": "employers",
    "displayName": "Employer",
    "description": "Companies participating in HireFlip hiring workflows."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "companyName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "required": true
    },
    "employerState": {
      "type": "enumeration",
      "enum": [
        "prospect",
        "invited",
        "active",
        "paused",
        "archived"
      ],
      "default": "prospect",
      "required": true
    },
    "region": {
      "type": "string",
      "maxLength": 120
    },
    "salesOwnerStaffUserId": {
      "type": "string",
      "maxLength": 160
    },
    "salesOwnerStaffEmail": {
      "type": "email",
      "maxLength": 254
    },
    "salesOwnerStaffDisplayName": {
      "type": "string",
      "maxLength": 240
    },
    "operatingRegions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::class-area.class-area"
    },
    "dashboardOnboardingState": {
      "type": "enumeration",
      "enum": [
        "not_started",
        "in_progress",
        "complete"
      ],
      "default": "not_started",
      "required": true
    },
    "dashboardOnboardingCompletedAt": {
      "type": "datetime"
    },
    "employerTermsAcceptedAt": {
      "type": "datetime"
    },
    "employerTermsAcceptedByEmail": {
      "type": "email",
      "maxLength": 254
    },
    "employerTermsPolicyDocumentId": {
      "type": "string",
      "maxLength": 120
    },
    "employerTermsPolicyVersion": {
      "type": "string",
      "maxLength": 120
    },
    "dashboardOnboardingMetadata": {
      "type": "json"
    },
    "sectorInterests": {
      "type": "json"
    },
    "roleInterests": {
      "type": "json"
    },
    "assignmentMode": {
      "type": "enumeration",
      "enum": [
        "automatic",
        "manual_masked_cv_review",
        "criteria_matching"
      ],
      "default": "automatic",
      "required": true
    },
    "interviewCommitmentVolume": {
      "type": "integer",
      "min": 0,
      "max": 1000
    },
    "initialInterviewCommitmentVolume": {
      "type": "integer",
      "min": 0,
      "max": 1000
    },
    "interviewCommitmentCadence": {
      "type": "enumeration",
      "enum": [
        "not_set",
        "quarterly",
        "biannually",
        "annually"
      ],
      "default": "not_set",
      "required": true
    },
    "initialInterviewCommitmentCadence": {
      "type": "enumeration",
      "enum": [
        "not_set",
        "quarterly",
        "biannually",
        "annually"
      ],
      "default": "not_set",
      "required": true
    },
    "commitmentMode": {
      "type": "enumeration",
      "enum": [
        "global",
        "per_region"
      ],
      "default": "global",
      "required": true
    },
    "capacityChangeRequestStatus": {
      "type": "enumeration",
      "enum": [
        "none",
        "pending",
        "approved",
        "denied"
      ],
      "default": "none",
      "required": true
    },
    "interviewCoverageOverrideAt": {
      "type": "datetime"
    },
    "interviewCoverageOverrideByEmail": {
      "type": "email",
      "maxLength": 254
    },
    "interviewCoverageOverrideByName": {
      "type": "string",
      "maxLength": 180
    },
    "interviewCoverageOverrideReason": {
      "type": "text"
    },
    "notes": {
      "type": "text"
    },
    "contacts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::employer-contact.employer-contact",
      "mappedBy": "employer"
    },
    "capacityChangeRequests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::employer-capacity-change-request.employer-capacity-change-request",
      "mappedBy": "employer"
    },
    "reliabilityEvents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::employer-reliability-event.employer-reliability-event",
      "mappedBy": "employer"
    },
    "regionCommitments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::employer-region-commitment.employer-region-commitment",
      "mappedBy": "employer"
    }
  }
}
