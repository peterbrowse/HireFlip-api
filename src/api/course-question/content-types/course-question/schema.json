{
  "kind": "collectionType",
  "collectionName": "course_questions",
  "info": {
    "singularName": "course-question",
    "pluralName": "course-questions",
    "displayName": "Course Question",
    "description": "Assessment question and scoring definition for a HireFlip course test."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "courseTest": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course-test.course-test",
      "inversedBy": "questions"
    },
    "prompt": {
      "type": "richtext",
      "required": true
    },
    "questionType": {
      "type": "enumeration",
      "enum": [
        "short_text",
        "long_text",
        "single_choice",
        "multiple_choice",
        "file_upload",
        "ai_reviewed",
        "external"
      ],
      "required": true
    },
    "options": {
      "type": "json"
    },
    "correctAnswerPayload": {
      "type": "json"
    },
    "scoringRubric": {
      "type": "json"
    },
    "sortOrder": {
      "type": "integer",
      "default": 0,
      "required": true
    },
    "randomizationGroup": {
      "type": "string"
    },
    "questionState": {
      "type": "enumeration",
      "enum": [
        "draft",
        "active",
        "archived"
      ],
      "default": "draft",
      "required": true
    }
  }
}
