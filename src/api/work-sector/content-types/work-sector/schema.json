{
  "kind": "collectionType",
  "collectionName": "work_sectors",
  "info": {
    "singularName": "work-sector",
    "pluralName": "work-sectors",
    "displayName": "Work Sector",
    "description": "Work sectors candidates can select for HireFlip class and career interest."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "active",
        "coming_soon",
        "hidden",
        "archived"
      ],
      "default": "active",
      "required": true
    },
    "sortOrder": {
      "type": "integer",
      "min": 0,
      "max": 10000,
      "default": 100
    },
    "notes": {
      "type": "text"
    },
    "classes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::class.class",
      "mappedBy": "workSector"
    }
  }
}
