{
  "kind": "collectionType",
  "collectionName": "classes",
  "info": {
    "singularName": "class",
    "pluralName": "classes",
    "displayName": "Class",
    "description": "A scheduled HireFlip class for a region, sector, and course version."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "required": true,
      "unique": true
    },
    "officialClassCode": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40,
      "required": true,
      "unique": true
    },
    "displayTitle": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "displayTitle"
    },
    "year": {
      "type": "integer",
      "min": 2026,
      "max": 2100
    },
    "yearSequenceNumber": {
      "type": "integer",
      "min": 1,
      "max": 999
    },
    "state": {
      "type": "enumeration",
      "enum": [
        "draft",
        "coming_soon",
        "waitlist_open",
        "open",
        "full",
        "in_progress",
        "completion_window",
        "interview_window",
        "completed",
        "cancelled",
        "archived"
      ],
      "default": "draft",
      "required": true
    },
    "level": {
      "type": "string",
      "maxLength": 80
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course",
      "inversedBy": "classes"
    },
    "classArea": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::class-area.class-area",
      "inversedBy": "classes"
    },
    "workSector": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::work-sector.work-sector",
      "inversedBy": "classes"
    },
    "startDate": {
      "type": "date"
    },
    "endDate": {
      "type": "date"
    },
    "completionDeadline": {
      "type": "datetime"
    },
    "interviewGuaranteeDeadline": {
      "type": "datetime"
    },
    "capacity": {
      "type": "integer",
      "min": 1,
      "max": 1000,
      "required": true
    },
    "interviewsGuaranteed": {
      "type": "integer",
      "min": 0,
      "max": 50,
      "required": true
    },
    "pricePence": {
      "type": "integer",
      "min": 0
    },
    "discountedPricePence": {
      "type": "integer",
      "min": 0
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "required": true
    },
    "region": {
      "type": "string",
      "maxLength": 120
    },
    "sector": {
      "type": "string",
      "maxLength": 120
    },
    "openedAt": {
      "type": "datetime"
    },
    "openingMode": {
      "type": "enumeration",
      "enum": [
        "manual_readiness",
        "admin_scheduled",
        "admin_immediate",
        "automatic",
        "automatic_when_ready",
        "automatic_at_capacity"
      ],
      "default": "manual_readiness",
      "required": true
    },
    "scheduledEnrollmentOpenAt": {
      "type": "datetime"
    },
    "enrollmentOpenedAt": {
      "type": "datetime"
    },
    "enrollmentOpenedBy": {
      "type": "string",
      "maxLength": 160
    },
    "automaticOpeningReadinessStatus": {
      "type": "enumeration",
      "enum": [
        "not_checked",
        "not_ready",
        "ready",
        "opened"
      ],
      "default": "not_checked",
      "required": true
    },
    "interestThresholdPercentage": {
      "type": "integer",
      "default": 200,
      "min": 1,
      "max": 1000
    },
    "employerInterviewAvailabilityThresholdPercentage": {
      "type": "integer",
      "default": 150,
      "min": 1,
      "max": 1000
    },
    "interviewCapacityContingencyPercentage": {
      "type": "integer",
      "default": 30,
      "min": 0,
      "max": 500
    },
    "minimumViableCapacity": {
      "type": "integer",
      "default": 1,
      "min": 1,
      "max": 1000
    },
    "openingReadinessStatus": {
      "type": "enumeration",
      "enum": [
        "not_checked",
        "blocked",
        "ready",
        "opened"
      ],
      "default": "not_checked",
      "required": true
    },
    "openingReadinessCheckedAt": {
      "type": "datetime"
    },
    "openingReadinessSummary": {
      "type": "json"
    },
    "openingCapacityReservationState": {
      "type": "enumeration",
      "enum": [
        "none",
        "reserved",
        "released",
        "consumed"
      ],
      "default": "none",
      "required": true
    },
    "openingCapacityReservation": {
      "type": "json"
    },
    "remoteInterviewsAllowed": {
      "type": "boolean",
      "default": false,
      "required": true
    },
    "modulesPassCriteriaAttached": {
      "type": "boolean",
      "default": false,
      "required": true
    },
    "closedAt": {
      "type": "datetime"
    },
    "overview": {
      "type": "text"
    },
    "includedItems": {
      "type": "json"
    },
    "moduleSummary": {
      "type": "text"
    },
    "scheduleNotes": {
      "type": "text"
    },
    "requirements": {
      "type": "text"
    },
    "faqs": {
      "type": "json"
    },
    "enrollments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::enrollment.enrollment",
      "mappedBy": "class"
    },
    "reservations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::reservation.reservation",
      "mappedBy": "class"
    },
    "interviewRequests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::interview-request.interview-request",
      "mappedBy": "class"
    }
  }
}
