{
  "kind": "collectionType",
  "collectionName": "candidate_profiles",
  "info": {
    "singularName": "candidate-profile",
    "pluralName": "candidate-profiles",
    "displayName": "Candidate Profile",
    "description": "Structured candidate CV/profile data used for generated documents and recruitment search."
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "candidate": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::candidate.candidate",
      "inversedBy": "profiles"
    },
    "profileState": {
      "type": "enumeration",
      "enum": [
        "draft",
        "in_review",
        "completed",
        "archived"
      ],
      "default": "draft",
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "targetSector": {
      "type": "string"
    },
    "targetSectorLabel": {
      "type": "string"
    },
    "targetRoleTitle": {
      "type": "string"
    },
    "targetRoleType": {
      "type": "enumeration",
      "enum": [
        "full_time",
        "part_time",
        "apprenticeship_internship",
        "flexible"
      ]
    },
    "preferredWorkStyle": {
      "type": "enumeration",
      "enum": [
        "in_person",
        "hybrid",
        "remote",
        "no_preference"
      ]
    },
    "earliestStartDate": {
      "type": "date"
    },
    "linkedinUrl": {
      "type": "string"
    },
    "portfolioUrl": {
      "type": "string"
    },
    "education": {
      "type": "json"
    },
    "experience": {
      "type": "json"
    },
    "projects": {
      "type": "json"
    },
    "skills": {
      "type": "json"
    },
    "workPreferences": {
      "type": "json"
    },
    "location": {
      "type": "string"
    },
    "availability": {
      "type": "string"
    },
    "unavailableDates": {
      "type": "json"
    },
    "availabilityNote": {
      "type": "text"
    },
    "availabilityConfirmedAt": {
      "type": "datetime"
    },
    "availabilityExpiresAt": {
      "type": "datetime"
    },
    "interviewFormatPreference": {
      "type": "enumeration",
      "enum": [
        "in_person_preferred",
        "remote_acceptable",
        "no_preference"
      ]
    },
    "readinessOverviewAcknowledgedAt": {
      "type": "datetime"
    },
    "recruitmentPlatformVisibility": {
      "type": "enumeration",
      "enum": [
        "not_set",
        "visible",
        "hidden"
      ],
      "default": "not_set",
      "required": true
    },
    "recruitmentVisibilityWordingVersion": {
      "type": "string"
    },
    "generatedCvFile": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::stored-file.stored-file"
    },
    "completedAt": {
      "type": "datetime"
    },
    "visibilityUpdatedAt": {
      "type": "datetime"
    },
    "metadata": {
      "type": "json"
    }
  }
}
