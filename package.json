{
  "name": "hireflip-api",
  "version": "0.1.0",
  "private": true,
  "description": "HireFlip core Strapi API",
  "scripts": {
    "build": "ENV_PATH=${ENV_PATH:-.env.local} strapi build",
    "console": "ENV_PATH=${ENV_PATH:-.env.local} strapi console",
    "deploy": "ENV_PATH=${ENV_PATH:-.env.local} strapi deploy",
    "dev": "ENV_PATH=${ENV_PATH:-.env.local} strapi develop",
