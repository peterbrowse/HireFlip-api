{
  "name": "hireflip-api",
  "version": "0.1.37",
  "private": true,
  "description": "HireFlip core Strapi API",
  "scripts": {
    "build": "ENV_PATH=${ENV_PATH:-.env.local} strapi build",
    "console": "ENV_PATH=${ENV_PATH:-.env.local} strapi console",
    "deploy": "ENV_PATH=${ENV_PATH:-.env.local} strapi deploy",
    "dev": "ENV_PATH=${ENV_PATH:-.env.local} strapi develop",
    "develop": "npm run dev",
    "start": "ENV_PATH=${ENV_PATH:-.env.local} strapi start",
    "strapi": "ENV_PATH=${ENV_PATH:-.env.local} strapi",
    "reset:class-data": "ENV_PATH=${ENV_PATH:-.env.local} node scripts/reset-class-data.js",
    "reconcile:payment-webhooks": "ENV_PATH=${ENV_PATH:-.env.local} node scripts/retry-payment-webhook-events.js",
    "seed:admin-roles": "ENV_PATH=${ENV_PATH:-.env.local} node scripts/seed-admin-roles.js",
    "seed:content": "ENV_PATH=${ENV_PATH:-.env.local} node scripts/seed-content.js",
    "seed:project-logos": "ENV_PATH=${ENV_PATH:-.env.local} node scripts/seed-project-logos.js",
    "seed:reset-content": "npm run reset:class-data && npm run seed:content",
    "seed:local-content": "npm run seed:content",
    "setup:e2e-fixtures": "ENV_PATH=${ENV_PATH:-.env.local} node scripts/setup-e2e-fixtures.js",
    "smoke:class-allocation": "ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-class-allocation.js",
    "smoke:class-realtime": "npm run build && ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-class-realtime.js",
    "smoke:class-workflows": "npm run build && ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-class-allocation.js && ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-waiting-list-offers.js && ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-class-realtime.js",
    "smoke:candidate-interview-slots": "npm run build && ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-candidate-interview-slots.js",
    "smoke:employer-dashboard": "npm run build && ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-employer-dashboard.js",
    "smoke:payment-edge-cases": "ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-payment-edge-cases.js",
    "smoke:payment-exception-refund": "npm run build && ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-payment-exception-refund.js",
    "smoke:notification-provider-template": "node scripts/smoke-notification-provider-template.js",
    "smoke:assessment-appeals": "npm run build && ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-assessment-appeals.js",
    "smoke:refund-provider-updates": "npm run build && ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-refund-provider-updates.js",
    "smoke:support-cases": "npm run build && ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-support-cases.js",
    "smoke:waiting-list-offers": "ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-waiting-list-offers.js",
    "smoke:mvp-dry-run": "ENV_PATH=${ENV_PATH:-.env.local} node scripts/smoke-mvp-dry-run.js",
    "upgrade": "npx @strapi/upgrade latest",
    "upgrade:dry": "npx @strapi/upgrade latest --dry"
  },
  "dependencies": {
    "@strapi/plugin-cloud": "5.47.0",
    "@strapi/plugin-users-permissions": "5.47.0",
    "@strapi/provider-email-notification-service": "file:providers/strapi-provider-email-notification-service",
    "@strapi/provider-upload-aws-s3": "5.47.0",
    "@strapi/strapi": "5.47.0",
    "better-sqlite3": "^12.10.0",
    "bullmq": "^5.77.7",
    "ioredis": "^5.11.0",
    "jose": "^6.2.3",
    "libphonenumber-js": "^1.13.3",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "pg": "8.8.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "sharp": "^0.33.5",
    "styled-components": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5"
  },
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "strapi": {
    "uuid": "9358c2ca-bd68-4d7f-985f-d3b93d55e98e",
    "installId": "bc31d04e8d8fbcec500a30518f1e0606a3f4527e7b9b012965f9239b77472cf9"
  }
}
