# Server
HOST=0.0.0.0
PORT=1337
APP_KEYS=your-app-key-1,your-app-key-2

# Database (Supabase / Postgres)
SUPABASE_DATABASE_URL=postgres://user:password@host:5432/dbname
SUPABASE_DATABASE_SSL_CA=base64-encoded-ca
SUPABASE_DATABASE_POOL_MIN=2
SUPABASE_DATABASE_POOL_MAX=10
SUPABASE_DATABASE_CONNECTION_TIMEOUT=60000

# Auth0
AUTH0_ISSUER=https://your-tenant-region.auth0.com/
AUTH0_AUDIENCE=hireflip-api
AUTH0_JWKS_URI=https://your-tenant-region.auth0.com/.well-known/jwks.json
AUTH0_ROLE_CLAIM=https://hireflip.com/roles

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cloudinary (uploads)
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=
CLOUDINARY_FOLDER=
