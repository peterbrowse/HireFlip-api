# Server
HOST=0.0.0.0
PORT=1337
# Public absolute API URL used for generated admin reset links and other absolute URLs.
# Deployed example: https://api.hireflip.work
PUBLIC_URL=

# Strapi secrets
# Generate each value with: openssl rand -base64 32
APP_KEYS=replace-me-1,replace-me-2,replace-me-3,replace-me-4
API_TOKEN_SALT=replace-me
ADMIN_JWT_SECRET=replace-me
TRANSFER_TOKEN_SALT=replace-me
ENCRYPTION_KEY=replace-me
JWT_SECRET=replace-me

# Database
# Local default:
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Deployed Postgres example:
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgres://user:password@host:5432/database
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10
# DATABASE_CONNECTION_TIMEOUT=60000

# Browser/app access
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3003,http://127.0.0.1:3003

# Uploads
# Local default is local. Deployed private product storage should use aws-s3.
UPLOAD_PROVIDER=local

# AWS S3 private product file storage
AWS_ACCESS_KEY_ID=
AWS_ACCESS_SECRET=
AWS_REGION=eu-west-2
AWS_BUCKET=
# Leave blank for modern private buckets with Object Ownership set to bucket-owner-enforced.
AWS_ACL=
# Keep enabled for private ACL-disabled buckets so Strapi returns signed preview/download URLs.
AWS_S3_SIGNED_URLS=true
AWS_SIGNED_URL_EXPIRES=900
AWS_S3_CSP_SOURCE=https://*.s3.amazonaws.com

# Future public media provider
CLOUDINARY_CSP_SOURCE=https://res.cloudinary.com

# Strapi system-email handoff through the notification service.
STRAPI_EMAIL_PROVIDER=notification-service
NOTIFICATION_SERVICE_URL=http://localhost:3010
NOTIFICATION_SERVICE_TOKEN=
NOTIFICATION_SERVICE_TIMEOUT_MS=5000
STRAPI_EMAIL_DEFAULT_FROM=no-reply@hireflip.work
STRAPI_EMAIL_DEFAULT_REPLY_TO=support@hireflip.work

# Payment service handoff
PAYMENT_SERVICE_URL=http://localhost:3002
PAYMENT_SERVICE_TOKEN=
PAYMENT_SERVICE_TIMEOUT_MS=5000

# AI service handoff. The API owns product state; the AI service only calls OpenAI.
AI_SERVICE_URL=http://localhost:3020
AI_SERVICE_TOKEN=
AI_SERVICE_TIMEOUT_MS=30000
CANDIDATE_CV_AUTOFILL_MAX_BYTES=6291456
CANDIDATE_CV_AUTOFILL_MIN_CHARACTERS=200
CANDIDATE_CV_AUTOFILL_MAX_CHARACTERS=60000
CANDIDATE_DASHBOARD_BASE_URL=http://localhost:3001
EMPLOYER_DASHBOARD_BASE_URL=http://localhost:3004
# Timed class place reservation window. Production default is 600 seconds.
CLASS_RESERVATION_WINDOW_SECONDS=600
# Redis-backed class allocation gate. Use a Redis instance owned by the core API, not the notification service Redis.
CLASS_ALLOCATION_REDIS_ENABLED=true
CLASS_ALLOCATION_REDIS_URL=redis://localhost:6379
CLASS_ALLOCATION_REDIS_PREFIX=hireflip:class-allocation
CLASS_ALLOCATION_REDIS_COMMAND_TIMEOUT_MS=2000
CLASS_ALLOCATION_REDIS_SYNC_LOCK_MS=10000
CLASS_ALLOCATION_REDIS_SYNC_TTL_SECONDS=300
CLASS_ALLOCATION_REDIS_TLS_REJECT_UNAUTHORIZED=false
# Redis pub/sub for candidate dashboard class updates. Defaults to the class allocation Redis URL.
CLASS_REALTIME_REDIS_URL=redis://localhost:6379
CLASS_REALTIME_REDIS_CHANNEL_PREFIX=hireflip:class-realtime
CLASS_REALTIME_REDIS_COMMAND_TIMEOUT_MS=2000
CLASS_REALTIME_REDIS_TLS_REJECT_UNAUTHORIZED=false
# Current class checkout terms version. Increment when the accepted terms copy changes materially.
CLASS_TERMS_VERSION=class-terms-v1
# Max failed Stripe webhook events and pending Stripe checkout payments reconciled by npm run reconcile:payment-webhooks.
PAYMENT_WEBHOOK_RETRY_LIMIT=50
# BullMQ-backed class workflow jobs. Uses the API Redis by default; Postgres remains the durable source of truth.
CLASS_WORKFLOW_QUEUE_ENABLED=true
CLASS_WORKFLOW_QUEUE_REDIS_URL=redis://localhost:6379
CLASS_WORKFLOW_QUEUE_PREFIX=hireflip:class-workflow
CLASS_WORKFLOW_QUEUE_NAME=class-workflow
CLASS_WORKFLOW_QUEUE_TLS_REJECT_UNAUTHORIZED=false
CLASS_WORKFLOW_QUEUE_WORKER_CONCURRENCY=2
CLASS_WORKFLOW_QUEUE_JOB_ATTEMPTS=5
CLASS_WORKFLOW_QUEUE_JOB_BACKOFF_MS=5000
CLASS_WORKFLOW_QUEUE_REMOVE_ON_COMPLETE=1000
CLASS_WORKFLOW_QUEUE_REMOVE_ON_FAIL=5000
CLASS_WORKFLOW_PAYMENT_RECONCILIATION_ENABLED=true
CLASS_WORKFLOW_PAYMENT_RECONCILIATION_INTERVAL_MS=60000
CLASS_WORKFLOW_PAYMENT_RECONCILIATION_LIMIT=50
CLASS_WORKFLOW_INTERVIEW_RECONCILIATION_ENABLED=true
CLASS_WORKFLOW_INTERVIEW_RECONCILIATION_INTERVAL_MS=60000
CLASS_WORKFLOW_INTERVIEW_RECONCILIATION_LIMIT=100
CLASS_WORKFLOW_WAITING_LIST_OFFER_SYNC_LIMIT=1000
EMPLOYER_CAPACITY_CLAIM_REMINDER_INTERVAL_HOURS=12
EMPLOYER_CAPACITY_CLAIM_REMINDER_MAX=4
EMPLOYER_INTERVIEW_DETAILS_REMINDER_INTERVAL_HOURS=12
EMPLOYER_INTERVIEW_DETAILS_REMINDER_MAX=4
CANDIDATE_INTERVIEW_SLOT_REMINDER_INTERVAL_HOURS=12
CANDIDATE_INTERVIEW_SLOT_REMINDER_MAX=4
# Waiting-list offers are exclusive timed claim windows after a waiting-list place becomes available.
WAITING_LIST_OFFER_WINDOW_SECONDS=900

# Public interest capture
PUBLIC_INTEREST_CONSENT_WORDING_VERSION=public-interest-v1
PUBLIC_INTEREST_ENQUIRY_LAWFUL_BASIS=legitimate_interests
PUBLIC_INTEREST_LEAD_SYNC_PROVIDER=webhook
PUBLIC_INTEREST_LEAD_SYNC_URL=
PUBLIC_INTEREST_LEAD_SYNC_TOKEN=
PUBLIC_INTEREST_LEAD_SYNC_LIST_ID=
PUBLIC_INTEREST_LEAD_SYNC_TIMEOUT_MS=10000
PUBLIC_INTEREST_LEAD_SYNC_BATCH_SIZE=50
PUBLIC_INTEREST_LEAD_SYNC_INCLUDE_FAILED=false
PUBLIC_INTEREST_LEAD_SYNC_DOCUMENT_ID=
PRIVACY_NOTICE_VERSION=privacy-notice-v1
TURNSTILE_SECRET_KEY=
TURNSTILE_ALLOWED_HOSTNAMES=localhost,127.0.0.1

# Candidate account onboarding
CANDIDATE_ACCOUNT_CONSENT_WORDING_VERSION=candidate-account-v1
CANDIDATE_PROFILE_IMAGE_FORMAT=webp
CANDIDATE_PROFILE_IMAGE_SIZE=512
CANDIDATE_PROFILE_IMAGE_QUALITY=82
CANDIDATE_PROFILE_IMAGE_MAX_BYTES=6291456

# Auth0 JWT verification for dashboard routes
AUTH0_DOMAIN=
AUTH0_ISSUER=
AUTH0_AUDIENCE=
AUTH0_ROLE_CLAIM=https://hireflip.work/roles
AUTH0_PERMISSION_CLAIM=permissions

# Auth0 Management API for gated employer dashboard invites and e2e fixture setup.
# Use a Machine-to-Machine application with create:users, read:users, update:users,
# create:user_tickets, and read:connections against the Auth0 Management API.
AUTH0_MANAGEMENT_DOMAIN=
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=
AUTH0_CANDIDATE_CONNECTION_NAME=hireflip-candidates
AUTH0_EMPLOYER_CONNECTION_NAME=hireflip-employers
AUTH0_EMPLOYER_CONNECTION_ID=
AUTH0_EMPLOYER_APP_CLIENT_ID=
AUTH0_EMPLOYER_PASSWORD_TICKET_TTL_SECONDS=172800

# Service-to-service route policy
# Store SHA-256 hashes of service tokens, not raw token values.
# Preferred format binds each token hash to the only service identity allowed to use it:
# admin-dashboard:<sha256>,candidate-dashboard:<sha256>,employer-dashboard:<sha256>,homepage:<sha256>,payment-service:<sha256>,notification-service:<sha256>
SERVICE_TOKEN_SHA256_BY_SERVICE=
# Legacy fallback for local/dev only. Do not use for production once the bound map is configured.
SERVICE_TOKEN_SHA256_HASHES=

# Custom admin dashboard auth/session
ADMIN_DASHBOARD_SESSION_TTL_SECONDS=28800
ADMIN_DASHBOARD_REMEMBER_ME_TTL_SECONDS=604800
ADMIN_DASHBOARD_PUBLIC_URL=http://localhost:3003
ADMIN_EMAIL_2FA_CODE_TTL_SECONDS=600
ADMIN_EMAIL_2FA_MAX_ATTEMPTS=5
ADMIN_EMAIL_2FA_RESEND_COOLDOWN_SECONDS=60
ADMIN_EMAIL_2FA_LOCKOUT_SECONDS=900

# Local/remote browser e2e fixtures. Use only allowlisted test accounts.
HIREFLIP_E2E_AUTH_ENABLED=false
HIREFLIP_E2E_ADMIN_EMAIL=
HIREFLIP_E2E_ADMIN_EMAILS=
HIREFLIP_E2E_ADMIN_PASSWORD=
HIREFLIP_E2E_ADMIN_OTP=
HIREFLIP_E2E_ADMIN_OTP_SKIP_EMAIL=true
HIREFLIP_E2E_CANDIDATE_EMAIL=
HIREFLIP_E2E_CANDIDATE_PASSWORD=
# Optional separate candidate for seeded interview browser states. Defaults to
# e2e-interview-candidate@hireflip.work and the normal e2e candidate password.
HIREFLIP_E2E_INTERVIEW_CANDIDATE_EMAIL=
HIREFLIP_E2E_INTERVIEW_CANDIDATE_PASSWORD=
HIREFLIP_E2E_EMPLOYER_EMAIL=
HIREFLIP_E2E_EMPLOYER_PASSWORD=
